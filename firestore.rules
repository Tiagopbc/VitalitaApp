rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper para verificar se o treinador tem vínculo com o estudante
    function isTrainerOf(studentId) {
      return request.auth != null && exists(/databases/$(database)/documents/trainer_students/$(studentId + '_' + request.auth.uid));
    }

    // 1. Coleção de Usuários
    match /users/{userId} {
      allow write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        isTrainerOf(userId)
      );
    }

    // 2. Coleção de Histórico de Treino
    match /workout_sessions/{sessionId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        isTrainerOf(resource.data.userId)
      );
    }
    
    // 3. Coleção de Templates de Treino
    match /workout_templates/{templateId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        isTrainerOf(resource.data.userId)
      );
    }

    // 4. Coleção de Vínculo Estudante-Treinador
    match /trainer_students/{linkId} {
      // O linkId deve ser composto: "studentId_trainerId"
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.studentId ||
        request.auth.uid == resource.data.trainerId
      );
      // Aluno pode criar vínculo consigo mesmo. Aluno ou Treinador podem deletar o vínculo.
      allow create: if request.auth != null && request.resource.data.studentId == request.auth.uid;
      allow delete: if request.auth != null && (
        resource.data.studentId == request.auth.uid ||
        resource.data.trainerId == request.auth.uid
      );
      // Impedir atualizações arbitrárias
      allow update: if false;
    }

    // 5. Coleção de Sessão Ativa
    match /active_workouts/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
